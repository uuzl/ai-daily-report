# ==================
# AI Daily Report 配置
# ==================
# 复制此文件为 .env 并填入实际值

# Tavily API Key (必需)
# 获取地址: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# 搜索关键词 (逗号分隔)
# 示例: "OpenAI news,Claude AI DeepSeek developments"
SEARCH_KEYWORDS=AI artificial intelligence news,OpenAI ChatGPT updates,Claude Anthropic release,DeepSeek AI developments,large language models LLM

# 最大新闻数量 (默认: 15)
MAX_ITEMS=15

# 输出目录 (默认: ./public)
OUTPUT_DIR=./public

# 站点 URL (自动生成，无需修改)
# SITE_URL=https://your-username.github.io/ai-daily-report
